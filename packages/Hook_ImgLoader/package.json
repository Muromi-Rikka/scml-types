{
  "name": "@scml/hook-img-loader",
  "version": "1.0.6",
  "private": false,
  "description": "TypeScript type definitions for image loader hook",
  "keywords": [
    "dol",
    "image-loader",
    "mod-loader",
    "scml",
    "sugarcube",
    "typescript"
  ],
  "homepage": "https://github.com/Muromi-Rikka/scml-types/tree/main/packages/Hook_ImgLoader#readme",
  "bugs": {
    "url": "https://github.com/Muromi-Rikka/scml-types/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Rikka",
    "email": "admin@rikka.cc",
    "url": "https://github.com/Muromi-Rikka"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Muromi-Rikka/scml-types.git",
    "directory": "packages/Hook_ImgLoader"
  },
  "files": [
    "type-dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./type-dist/global.d.ts",
  "exports": {
    ".": "./type-dist/global.d.ts",
    "./utils": "./type-dist/utils.d.ts",
    "./SimpleDolFunctionHook": "./type-dist/SimpleDolFunctionHook.d.ts",
    "./NodeMutationObserver": "./type-dist/NodeMutationObserver.d.ts",
    "./ImgLoaderHookerCore": "./type-dist/ImgLoaderHookerCore.d.ts",
    "./ImgLoaderHooker": "./type-dist/ImgLoaderHooker.d.ts",
    "./CssReplacer": "./type-dist/CssReplacer.d.ts",
    "./createFunctionFromCode": "./type-dist/createFunctionFromCode.d.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "download": "tsx src/download.ts",
    "build": "tsdown && tsx src/after-build.ts",
    "typecheck": "tsc --noEmit",
    "publint": "publint"
  },
  "dependencies": {
    "@scml/sc2-modloader": "workspace:*"
  }
}
