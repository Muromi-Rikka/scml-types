{
  "name": "@scml/mod-twee-replacer",
  "version": "1.0.7",
  "private": false,
  "description": "TypeScript type definitions for twee replacer mod",
  "keywords": [
    "dol",
    "mod-loader",
    "scml",
    "sugarcube",
    "typescript"
  ],
  "homepage": "https://github.com/Muromi-Rikka/scml-types/tree/main/packages/Mod_TweeReplacer#readme",
  "bugs": {
    "url": "https://github.com/Muromi-Rikka/scml-types/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Rikka",
    "email": "admin@rikka.cc",
    "url": "https://github.com/Muromi-Rikka"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Muromi-Rikka/scml-types.git",
    "directory": "packages/Mod_TweeReplacer"
  },
  "files": [
    "type-dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./type-dist/global.d.ts",
  "exports": {
    ".": "./type-dist/global.d.ts",
    "./TweeReplacer": "./type-dist/TweeReplacer.d.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "download": "tsx src/download.ts",
    "build": "tsdown && tsx src/after-build.ts",
    "typecheck": "tsc --noEmit",
    "publint": "publint"
  },
  "dependencies": {
    "@scml/addon-twee-replacer-linker": "workspace:*",
    "@scml/sc2-modloader": "workspace:*"
  }
}
