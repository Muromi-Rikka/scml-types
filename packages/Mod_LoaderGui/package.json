{
  "name": "@scml/mod-loader-gui",
  "version": "1.0.6",
  "private": false,
  "description": "TypeScript type definitions for mod loader GUI",
  "keywords": [
    "dol",
    "gui",
    "mod-loader",
    "scml",
    "sugarcube",
    "typescript"
  ],
  "homepage": "https://github.com/Muromi-Rikka/scml-types/tree/main/packages/Mod_LoaderGui#readme",
  "bugs": {
    "url": "https://github.com/Muromi-Rikka/scml-types/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Rikka",
    "email": "admin@rikka.cc",
    "url": "https://github.com/Muromi-Rikka"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Muromi-Rikka/scml-types.git",
    "directory": "packages/Mod_LoaderGui"
  },
  "files": [
    "type-dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./type-dist/global.d.ts",
  "exports": {
    ".": "./type-dist/global.d.ts",
    "./DebugExport": "./type-dist/DebugExport.d.ts",
    "./Gui": "./type-dist/Gui.d.ts",
    "./KeyFilter": "./type-dist/KeyFilter.d.ts",
    "./LoadingProgress": "./type-dist/LoadingProgress.d.ts",
    "./ModLoadSwitch": "./type-dist/ModLoadSwitch.d.ts",
    "./ModManagerSubUi": "./type-dist/ModManagerSubUi.d.ts",
    "./ModSubUiAngularJsService": "./type-dist/ModSubUiAngularJsService.d.ts",
    "./ModSubUiAngularJsServiceInterface": "./type-dist/ModSubUiAngularJsServiceInterface.d.ts",
    "./PassageTracer": "./type-dist/PassageTracer.d.ts",
    "./GUI_StringTable/CN": "./type-dist/GUI_StringTable/CN.d.ts",
    "./GUI_StringTable/EN": "./type-dist/GUI_StringTable/EN.d.ts",
    "./GUI_StringTable/StringTable": "./type-dist/GUI_StringTable/StringTable.d.ts",
    "./GM_config_TS/gm_config": "./type-dist/GM_config_TS/gm_config.d.ts",
    "./GM_config_TS/Greasemonkey": "./type-dist/GM_config_TS/Greasemonkey.d.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "download": "tsx src/download.ts",
    "build": "tsdown && tsx src/after-build.ts",
    "typecheck": "tsc --noEmit",
    "publint": "publint"
  },
  "dependencies": {
    "@scml/mod-sub-ui-angular-js": "workspace:*",
    "@scml/sc2-modloader": "workspace:*"
  },
  "devDependencies": {
    "angular": "^1.8.3"
  }
}
