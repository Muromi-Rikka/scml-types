{
  "name": "@scml/mod-sub-ui-angular-js",
  "version": "1.0.7",
  "private": false,
  "description": "TypeScript type definitions for sub UI AngularJS mod",
  "keywords": [
    "angularjs",
    "dol",
    "mod-loader",
    "scml",
    "sugarcube",
    "typescript"
  ],
  "homepage": "https://github.com/Muromi-Rikka/scml-types/tree/main/packages/Mod_SubUiAngularJs#readme",
  "bugs": {
    "url": "https://github.com/Muromi-Rikka/scml-types/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Rikka",
    "email": "admin@rikka.cc",
    "url": "https://github.com/Muromi-Rikka"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Muromi-Rikka/scml-types.git",
    "directory": "packages/Mod_SubUiAngularJs"
  },
  "files": [
    "type-dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./type-dist/global.d.ts",
  "exports": {
    ".": "./type-dist/global.d.ts",
    "./AppContainerManagerMethodsInterface": "./type-dist/AppContainerManagerMethodsInterface.d.ts",
    "./ModSubUiAngularJs": "./type-dist/ModSubUiAngularJs.d.ts",
    "./ModSubUiAngularJsBody": "./type-dist/ModSubUiAngularJsBody.d.ts",
    "./ModSubUiAngularJsModeExportInterface": "./type-dist/ModSubUiAngularJsModeExportInterface.d.ts",
    "./AngularJs/appInit": "./type-dist/AngularJs/appInit.d.ts",
    "./AngularJs/ExternalComponentManager": "./type-dist/AngularJs/ExternalComponentManager.d.ts",
    "./AngularJs/ExternalComponentManagerInterface": "./type-dist/AngularJs/ExternalComponentManagerInterface.d.ts",
    "./AngularJs/Componnet/EnableOrderComponent": "./type-dist/AngularJs/Componnet/EnableOrderComponent.d.ts",
    "./AngularJs/Componnet/OrderComponent": "./type-dist/AngularJs/Componnet/OrderComponent.d.ts",
    "./AngularJs/Componnet/SimpleSelectComponent": "./type-dist/AngularJs/Componnet/SimpleSelectComponent.d.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "download": "tsx src/download.ts",
    "build": "tsdown && tsx src/after-build.ts",
    "typecheck": "tsc --noEmit",
    "publint": "publint"
  },
  "dependencies": {
    "@scml/sc2-modloader": "workspace:*"
  }
}
